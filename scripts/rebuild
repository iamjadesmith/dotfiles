#!/bin/bash
set -euo pipefail

dotfiles_dir="${DOTFILES_DIR:-$HOME/.dotfiles}"
flake_dir="${dotfiles_dir}/nix"

if [[ ! -d "$flake_dir" ]]; then
  echo "error: Nix flake directory not found: $flake_dir" >&2
  exit 1
fi

if git -C "$dotfiles_dir" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
  status=$(git -C "$dotfiles_dir" status --short)
  if [[ -n "$status" ]]; then
    printf 'Dotfiles working tree has local changes:\n%s\n\n' "$status"
  fi
fi

case "$(uname -s)" in
  Darwin)
    exec sudo darwin-rebuild switch --flake "path:${flake_dir}#mac"
    ;;
  Linux)
    exec sudo nixos-rebuild switch --flake "path:${flake_dir}#$(hostname)"
    ;;
  *)
    echo "error: unsupported platform: $(uname -s)" >&2
    exit 1
    ;;
esac
